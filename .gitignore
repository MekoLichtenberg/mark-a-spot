# Ignore directories generated by Composer
drush/contrib
vendor
web/core
web/modules/contrib
web/themes/contrib
web/profiles/contrib
web/libraries
# Ignore Drupal's file directory
web/sites/*/files

# Ignore files generated by PhpStorm
.idea

# Ignore files generated by MacOS
.DS_Store

# Ignore configuration files that may contain sensitive information.
web/sites/*/settings.local.php
web/sites/*/settings.prod.php
web/sites/*/settings.php

/.csslintrc
/.editorconfig
/.eslintignore
/.eslintrc.json
/.gitattributes
/.ht.router.php
/.htaccess
/INSTALL.txt
/README.txt
/autoload.php
/example.gitignore
/index.php
/robots.txt
/update.php
/web.config
*.log
web/modules/custom/markaspot_vision/
translations/*.po
.vercel

# Config-less distribution: the markaspot install profile seeds from
# config/install (site:install WITHOUT --existing-config), not config/sync.
# Keep the dir present for fresh clones via .gitkeep; ignore local exports.
config/sync/*
!config/sync/.gitkeep

# Documentation: active sibling repo (own remote, deployed to Vercel) + local
# doc notes — separate projects, not part of the distribution.
/markaspot-user-guide/
/docs/feature-requests/
/docs/jurisdiction-scoped-request-ids.md
/docs/seed-amsterdam-status-attributes.md

# Drupal test-runner artifacts (regenerated per run)
/sites/
web/sites/simpletest/
